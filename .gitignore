# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py

# Flask stuff:
instance/
.webassets-cache

# Local runtime configuration (do not commit secrets)
config.py
config.local.py
*.local.py

# Certificates / keys
cert/
certs/
*.pem
*.key

# Scrapy stuff:
.scrapy

# Sphinx documentation
docs/_build/

# PyBuilder
target/

# Jupyter Notebook
.ipynb_checkpoints

# pyenv
.python-version

# celery beat schedule file
celerybeat-schedule

# SageMath parsed files
*.sage.py

# dotenv
.env

# virtualenv
.venv
venv/
ENV/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
license_tracker/__pycache__/
license_tracker/api/__pycache__/
license_tracker/extensions/__pycache__/
license_tracker/models/__pycache__/
license_tracker/ui/node_modules/

# Built UI artifacts (can embed environment-specific URLs)
license_tracker/license_tracker/ui/assets/bundle.js
license_tracker/license_tracker/ui/assets/bundle.js.map

# Remove/ignore org-branded assets
license_tracker/license_tracker/ui/assets/images/*gkn*
license_tracker/license_tracker/ui/assets/images/*GKN*
logs/
