# =============================================================================
# LICENSE TRACKER - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# ENVIRONMENT MODE
# -----------------------------------------------------------------------------
FLASK_ENV=production
NODE_ENV=production

# -----------------------------------------------------------------------------
# SSL/HTTPS CONFIGURATION
# -----------------------------------------------------------------------------
# Set to 'true' to enable HTTPS, leave empty or 'false' for HTTP
SSL_ENABLED=false
# Directory containing SSL certificates (inside container)
SSL_CERT_DIR=/opt/license_tracker/certs
# Certificate filenames (relative to SSL_CERT_DIR)
SSL_CERT_FILE=server_certificate.pem
SSL_KEY_FILE=server_key.key

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION (SENSITIVE)
# -----------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=license_tracker
MYSQL_USER=license_user
MYSQL_PASSWORD=license_password

# Full database URI (auto-constructed if not provided)
# Format: mysql+pymysql://user:password@host:port/database
SQLALCHEMY_DATABASE_URI=mysql+pymysql://license_user:license_password@db:3306/license_tracker

# Database connection pool settings
SQLALCHEMY_POOL_SIZE=10
SQLALCHEMY_POOL_TIMEOUT=600
SQLALCHEMY_POOL_RECYCLE=500

# -----------------------------------------------------------------------------
# APPLICATION SECRETS (SENSITIVE - CHANGE IN PRODUCTION!)
# -----------------------------------------------------------------------------
# Generate with: python -c "import os; print(os.urandom(32).hex())"
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# -----------------------------------------------------------------------------
# BACKEND CONFIGURATION
# -----------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=2324
CFG_LOCATION=/opt/license_tracker/instance/config.py
CORS_ORIGINS=http://localhost:3000,http://frontend:3000

# Gunicorn settings
GUNICORN_WORKERS=10
GUNICORN_TIMEOUT=240
GUNICORN_LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# FRONTEND CONFIGURATION
# -----------------------------------------------------------------------------
FRONTEND_PORT=3000
BACKEND_URL=http://backend:2324

# -----------------------------------------------------------------------------
# PROXY CONFIGURATION (optional, for corporate networks)
# -----------------------------------------------------------------------------
HTTP_PROXY=
HTTPS_PROXY=

# -----------------------------------------------------------------------------
# LICENSE SERVER CONFIGURATION
# -----------------------------------------------------------------------------
# MSC License Servers
APAC_MSC=
EU_MSC=
AME_MSC=
CLUSTER_MSC=
MSC_PORT=27500
AME_MSC_PORT=1700

# Altair License Servers
EU_ALTAIR=
APAC_ALTAIR=
EU_UNLIMITED_ALTAIR=
APAC_UNLIMITED_ALTAIR=
AME_ALTAIR=
ALTAIR_PORT=6200

# Other License Servers
PARTICLEWORKS=
PW_PORT=27000
RECARDO=
RECARDO_PORT=27006
MASTA=
MASTA_PORT=5053
RLM=
RLM_PORT=5053

# Utility paths (inside container)
ALMTUTIL_PATH=/opt/license_tracker/utils/almutil
LMTUTIL_PATH=/opt/license_tracker/utils/lmutil
RLMTUTIL_PATH=/opt/license_tracker/utils/rlmutil
PARTICLEWORKS_LMUTIL_PATH=

# -----------------------------------------------------------------------------
# REDMINE INTEGRATION (SENSITIVE)
# -----------------------------------------------------------------------------
REDMINE_ADDRESS=
REDMINE_API_KEY=
REDMINE_SAFELIST_TOKEN=

# -----------------------------------------------------------------------------
# AUTHENTICATION CREDENTIALS (SENSITIVE)
# -----------------------------------------------------------------------------
MASTER_PASSWORD=
USERNAME=
PASSWORD=
GUEST_SVN_USERNAME=
GUEST_SVN_PASSWORD=
LINUX_USER_NAME=
LINUX_PASSWORD=

# -----------------------------------------------------------------------------
# OTHER SETTINGS
# -----------------------------------------------------------------------------
SERVER_IP=
DB_NAME=
DB_TYPE=
SITECODE=Site Short Code
